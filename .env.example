# PostgreSQL
POSTGRES_USER=achilles
POSTGRES_PASSWORD=<your-password>
POSTGRES_DB=achilles

# Redis (durable: queues/counters · cache: evictable cache)
REDIS_PASSWORD=<generate-with-openssl-rand-base64-24>

# Backend
SECRET_KEY=<generate-with-openssl-rand-base64-32>
LOG_LEVEL=info
CORS_ORIGINS=["http://localhost:3000"]

# Email (links in emails are built from this URL; dev SMTP — mailpit :1025/:8025)
PUBLIC_BASE_URL=http://localhost:3000

# Frontend (dev proxy)
API_PROXY_TARGET=http://backend:8000

# Production (docker-compose.prod.yml)
DOMAIN=your-domain.com
VITE_API_URL=https://your-domain.com/api

# Optional tuning:
# REDIS_MAXMEMORY=256mb
# NGINX_PORT=80
# NGINX_SSL_PORT=443
#
# SAQ slots per lane process (defaults 10/4/8 — backend config.py):
# WORKER_CONCURRENCY_INTERACTIVE=10
# WORKER_CONCURRENCY_BACKGROUND=4
# WORKER_CONCURRENCY_AGENTS=8
