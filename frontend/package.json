{
  "name": "achilles-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint .",
    "lint:fix": "eslint --fix --cache --cache-location node_modules/.cache/eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check --cache \"**/*.{ts,tsx,css,json}\"",
    "check": "tsc -b && eslint --cache --cache-location node_modules/.cache/eslint . && prettier --check --cache \"**/*.{ts,tsx,css,json}\"",
    "knip": "knip",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.24",
    "@assistant-ui/react-markdown": "^0.14.5",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource-variable/rubik": "^5.2.8",
    "@tanstack/react-query": "^5.100.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eventsource-parser": "^3.1.0",
    "i18next": "^26.2.0",
    "ky": "^2.0.2",
    "lucide-react": "^1.16.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.7.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vitest": "^4.1.9"
  }
}
